# ── Refinery Nexus Backend ──
# Copy this file to .env and fill in real values

# Server
PORT=4000
NODE_ENV=development

# ClickHouse
CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=refinery

# AWS S3 (5x5 Co-Op Source)
S3_SOURCE_BUCKET=
S3_SOURCE_REGION=us-east-1
S3_SOURCE_ACCESS_KEY=
S3_SOURCE_SECRET_KEY=

# Linode Object Storage (Destination)
LINODE_OBJ_ENDPOINT=https://us-east-1.linodeobjects.com
LINODE_OBJ_BUCKET=refinery-data
LINODE_OBJ_ACCESS_KEY=
LINODE_OBJ_SECRET_KEY=

# Verify550
VERIFY550_ENDPOINT=https://api.verify550.com/v1
VERIFY550_API_KEY=
VERIFY550_BATCH_SIZE=5000
VERIFY550_CONCURRENCY=3

# SMTP / Email Relay
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_RATE_LIMIT_PER_HOUR=500

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173
